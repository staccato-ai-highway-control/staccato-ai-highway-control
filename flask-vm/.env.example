APP_ENV=development

# Database
DATABASE_HOST=YOUR_DB_HOST
DATABASE_PORT=3306
DATABASE_NAME=staccato
DATABASE_USER=YOUR_DB_USER
DATABASE_PASSWORD=YOUR_DB_PASSWORD

# Internal Server URLs
AI_SERVER_URL=http://YOUR_AI_SERVER_HOST:8001
LLM_SERVER_URL=http://YOUR_LLM_SERVER_HOST:8000
ITS_SERVER_URL=http://YOUR_ITS_SERVER_HOST:8000

# Security
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY
INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_API_TOKEN

# Frontend
FRONTEND_BASE_URL=http://YOUR_FRONTEND_HOST:3001
CORS_ORIGINS=http://YOUR_FRONTEND_HOST:3001
SOCKETIO_CORS_ORIGINS=http://YOUR_FRONTEND_HOST:3001