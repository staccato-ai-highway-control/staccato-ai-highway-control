# =========================
# STACCATO Docker Environment
# =========================

# Timezone
TZ=Asia/Seoul

# Server Ports
FRONTEND_PORT=3001
FLASK_PORT=5000
AI_PORT=8001
ITS_PORT=8002
MYSQL_PORT=3307
LLM_PORT=8000

# MySQL
MYSQL_DATABASE=staccato
MYSQL_USER=staccato_user
MYSQL_PASSWORD=staccato_password
MYSQL_ROOT_PASSWORD=root_password

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
DATABASE_URL=mysql+pymysql://staccato_user:staccato_password@db-server:3306/staccato

# Internal Service URLs
AI_SERVER_URL=http://ai-server:8001
ITS_SERVER_URL=http://its-server:8002

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Email / SMTP
MAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
MAIL_FROM=no-reply@staccato.local

# Email Verification
FRONTEND_BASE_URL=http://localhost:3001
EMAIL_VERIFICATION_REQUIRED=false

# LLM
LLM_ENABLED=true
LLM_PROVIDER=MOCK
LLM_SERVER_URL=http://llm-server:8000
LLM_SERVER_TIMEOUT_SECONDS=30

# OPENAI Provider, optional
OPENAI_API_KEY=
OPENAI_MODEL=

# Storage
STORAGE_ROOT=/app/storage
UPLOAD_DIR=/app/storage/uploads
SNAPSHOT_DIR=/app/storage/snapshots
MODEL_DIR=/app/storage/models
DATASET_DIR=/app/storage/datasets
TRAINING_LOG_DIR=/app/storage/training-logs
# Auth
SECRET_KEY=local-dev-secret-key
JWT_SECRET_KEY=local-dev-jwt-secret-key
JWT_EXPIRES_HOURS=12
