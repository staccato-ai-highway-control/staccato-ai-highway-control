#!/usr/bin/env bash
set -euo pipefail

SERVICE="staccato-ai-server.service"

echo "========== AI-VM STATUS =========="
sudo systemctl status "$SERVICE" --no-pager -l | head -50 || true

echo
echo "========== PORT 5001 =========="
ss -ltnp | grep ':5001' || echo "AI-vm 5001 is not listening"

echo
echo "========== HEALTH =========="
curl --max-time 10 -sS http://localhost:5001/health || echo "AI-vm health check failed"
